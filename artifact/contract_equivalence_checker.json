{
  "artifact": "contract_equivalence_checker",
  "conditions": [
    {
      "id": "P0_durable_receipt",
      "meaning": "receive id and payload hash are durable before parsing, verification, or rejection"
    },
    {
      "id": "P1_attested_execution_commitment",
      "meaning": "report commitment and certificate fields are bound to allowed attested execution"
    },
    {
      "id": "P2_source_token_consumption",
      "meaning": "issued source token is conditionally consumed at most once"
    },
    {
      "id": "P3_separate_uniqueness",
      "meaning": "terminal, source, counter, and nonce keys are separately unique"
    },
    {
      "id": "P4_policy_price_join",
      "meaning": "accepted row joins an allowed policy and price row before visibility"
    },
    {
      "id": "P5_disclosure_rule",
      "meaning": "exact, private-exact, or restricted-disclosure rule is checked"
    },
    {
      "id": "P6_residual_evidence",
      "meaning": "restricted-disclosure rows include required residual-control evidence"
    },
    {
      "id": "P7_idempotent_recovery",
      "meaning": "retries and crashes cannot expose partial accepted rows or duplicate queue entries"
    },
    {
      "id": "V1_accepted_only_visibility",
      "meaning": "payment, buyer, and estimator queries see only rows that passed admission"
    },
    {
      "id": "V2_queryable_rejections",
      "meaning": "malformed durable receives and parsed deterministic failures have queryable rejection reasons and no queue entry"
    },
    {
      "id": "V3_consumed_missing_accounting",
      "meaning": "expired precommit or release attempts are counted and excluded from aggregation"
    }
  ],
